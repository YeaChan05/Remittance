@startuml
left to right direction

title "Hexagonal Application - Internal Communication Guide"

actor user as "user"

rectangle provider as "Provider Domain" {
    package provider_api_internal as "api-internal" {
        package provider_contract as "internal.contract" {
            interface ProviderInternalApi
            class ProviderRequest
            class ProviderResponse
        }

        package provider_adapter as "internal.adapter" {
            class ProviderInternalAdapter
        }

        ProviderInternalAdapter ..> ProviderInternalApi
        ProviderInternalAdapter ..> ProviderRequest
        ProviderInternalAdapter ..> ProviderResponse
    }

    package provider_service as "service" {
        interface ProviderUseCase
    }

    ProviderInternalAdapter --> ProviderUseCase
}

rectangle consumer as "Consumer Domain" {
    package consumer_api as "api" {
        class ConsumerController
    }

    package consumer_service as "service" {
        class ConsumerService
    }

    package consumer_infrastructure as "infrastructure" {
        interface ProviderClient
        class ProviderClientAdapter
    }

    ConsumerController --> ConsumerService
    ConsumerService --> ProviderClient
    ProviderClientAdapter ..> ProviderClient
    ProviderClientAdapter ..> ProviderInternalApi
}

rectangle persistence as "Driven Adapter" {
    class RepositoryImpl
}

ProviderUseCase --> RepositoryImpl
user --> ConsumerController

note bottom of consumer
Actual rule:
service -> own infrastructure -> provider api-internal.internal.contract
end note

note bottom of provider
api-internal-client is not used in the current repo.
It remains a future extension option only.
end note

@enduml

@startuml
left to right direction

title "Hexagonal Application - Package Naming Guide"

package provider_api_internal as "provider:api-internal" {
    package contract as "internal.contract" {
        interface DomainInternalApi
        class DomainActionRequest
        class DomainActionResponse
    }

    package adapter as "internal.adapter" {
        class DomainInternalAdapter
        class DomainInternalApiAutoConfiguration
    }

    DomainInternalAdapter ..> DomainInternalApi
    DomainInternalApiAutoConfiguration ..> DomainInternalAdapter
}

package consumer_infrastructure as "consumer:infrastructure" {
    interface DomainClient
    class DomainClientAdapter
    class DomainSnapshot
    class DomainCommand

    DomainClientAdapter ..> DomainClient
    DomainClientAdapter ..> DomainInternalApi
}

package consumer_service as "consumer:service" {
    class ConsumerUseCase
    ConsumerUseCase --> DomainClient
}

note bottom of consumer_infrastructure
Current standard:
- DomainClient
- DomainClientAdapter
- DomainSnapshot / DomainCommand
end note

note bottom of provider_api_internal
Current standard:
- internal.contract
- internal.adapter
end note

@enduml
